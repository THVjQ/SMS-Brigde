{
  "manifest_version": 3,
  "name": "SOS Messenger",
  "version": "2.1",
  "description": "Send SMS from your browser via your Android phone",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icon16.png",
      "32":  "icon32.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ]
}
